# Wajib diisi untuk runtime chat/CV/vision/output yang full LLM-based

OPENAI_MODEL="gpt-40-mini"
VISION_MODEL="gpt-40-mini"
EMBEDDING_MODEL="text-embedding-3-small"

# Wajib diisi ke endpoint Qdrant eksternal yang bisa diakses Cloud Run
# Contoh: https://<cluster>.gcp.cloud.qdrant.io
QDRANT_URL="
QDRANT_API_KEY=
QDRANT_COLLECTION_NAME="smartjobs_jobs"

SQLITE_PATH="dataset/processed/data.sqlite"
RAW_DATASET_PATH="dataset/raw/jobs.jsonl"
CLEANED_JSONL_PATH="dataset/processed/jobs_cleaned.jsonl"
CHUNKS_PREVIEW_PATH="dataset/processed/chunks_preview.jsonl"

APP_HOST="0.0.0.0"
APP_PORT=8080
API_URL="https://smartjobs-api-94453605119.us-central1.run.app"

LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST="https://cloud.langfuse.com"
